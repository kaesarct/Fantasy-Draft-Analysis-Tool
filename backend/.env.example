# FT Platform Backend — .env example
DB_HOST=localhost
DB_PORT=5432
DB_USER=ft_user
DB_PASSWORD=ft_password
DB_NAME=ft_platform

FANTA_USERNAME=your_fantacalcio_email
FANTA_PASSWORD=your_fantacalcio_password
# Codice stagione fantacalcio.it = anno_inizio_stagione - 2005 (es. 2025-26 -> 20).
# Un codice sbagliato (es. una stagione futura non ancora pubblicata) fa
# rispondere l'API con 200 OK ma un file Excel vuoto (0 byte).
FANTA_YEAR_QUOTAZIONI=20
FANTA_LEGA_NAME=fantacalcio-tamarros

DEBUG=false
LOG_LEVEL=INFO
CORS_ORIGINS=["http://localhost:4200"]
DOWNLOAD_FOLDER=./downloads/
UPLOAD_FOLDER=./uploads/logos/

# ── Login admin (protegge sync/import/scrittura) ──────────────────────────
ADMIN_USERNAME=admin
# Genera con: python -m app.services.auth_service <password>
ADMIN_PASSWORD_HASH=
# Genera con: openssl rand -hex 32
JWT_SECRET=
JWT_EXPIRE_MINUTES=43200
# Metti false SOLO in sviluppo locale su http://localhost (il cookie Secure
# richiede HTTPS; in produzione deve restare true).
COOKIE_SECURE=true
