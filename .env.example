# Configurazione di Base
SECRET_KEY=tua_secret_key_super_sicura_da_sostituire
# In produzione impostare DEBUG=False
DEBUG=True
# Host consentiti (separati da virgola), es. dominio di produzione
ALLOWED_HOSTS=localhost,127.0.0.1

# Secret token del webhook Telegram (header X-Telegram-Bot-Api-Secret-Token)
TELEGRAM_WEBHOOK_SECRET=

# Credenziali API Fanta (Da usare nei tuoi script)
FANTA_USERNAME=tuo_username
FANTA_PASSWORD=tua_password
BASE_URL=https://api.fantacalcio.it/
BASE_API=v1/
# Sito web (scraping live partite e probabili formazioni)
BASE_URL_SITE=https://www.fantacalcio.it/

GEMINI_API_KEY=la_tua_chiave_api_gemini

# Impostazioni Database PostgreSQL (De-commenta se non vuoi usare SQLite)
# DB_NAME=fanta_db
# DB_USER=postgres
# DB_PASSWORD=postgres
# DB_HOST=localhost
# DB_PORT=5432
