# Root .env — letto da docker-compose.yml e docker-compose.prod.yml per la
# sostituzione delle variabili (${VAR}). Non e' lo stesso file di
# backend/.env: quest'ultimo serve solo per l'esecuzione locale del backend
# senza Docker (uvicorn diretto); Docker Compose legge SOLO questo file.
#
# Copia in .env (gitignorato) e compila con i valori reali:
#   cp .env.example .env

# ── Fantacalcio.it (usato sia da docker-compose.yml che .prod.yml) ────────
FANTA_USERNAME=your_fantacalcio_email
FANTA_PASSWORD=your_fantacalcio_password
# Codice stagione fantacalcio.it = anno_inizio_stagione - 2005 (es. 2025-26 -> 20).
FANTA_YEAR_QUOTAZIONI=20
FANTA_LEGA_NAME=fantacalcio-tamarros

# ── PostgreSQL (usato solo da docker-compose.prod.yml — nello stack di ────
# ── sviluppo le credenziali sono hardcoded in docker-compose.yml) ─────────
DB_USER=ft_user
DB_PASSWORD=change-me-before-going-to-production
DB_NAME=ft_platform

# ── CORS (usato solo da docker-compose.prod.yml) ──────────────────────────
CORS_ORIGINS=["https://tuonome.synology.me"]
